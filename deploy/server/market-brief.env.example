# Non-secret service configuration. Copy to /etc/market-brief.env (mode 600).
MARKET_BRIEF_PROJECT=/opt/market-brief
MARKET_BRIEF_PYTHON=/opt/market-brief/.venv/bin/python
CLAUDE_BIN=/home/marketbrief/.local/bin/claude
TZ=America/Chicago
# Identifiable crawler contact required by BLS/SEC fair-access policies.
# MARKET_BRIEF_CONTACT=operator@example.com

# Private Cloud Run viewer publication. The VM service account needs write
# access only to this bucket; the viewer service account is read-only.
# GCP_PROJECT_ID=your-project-id
# MARKET_BRIEF_GCS_BUCKET=your-private-bucket
# MARKET_BRIEF_WEB_URL=https://your-private-viewer.run.app

# Optional Gmail completion email. Use a Google App Password, never the normal
# account password, and keep /etc/market-brief.env mode 600.
# GMAIL_SMTP_USER=you@gmail.com
# GMAIL_APP_PASSWORD=replace_with_16_digit_app_password
# MARKET_BRIEF_EMAIL_TO=you@gmail.com

# The systemd unit defaults to the portable NVIDIA/Z.AI -> Kimi backend.
# Override only if deliberately switching back to Claude Code:
# MARKET_BRIEF_RUNNER=/opt/market-brief/run.sh
# NVIDIA_API_KEY=replace_me
# ZAI_API_KEY=replace_me
# MOONSHOT_API_KEY=replace_me

# Hybrid writer route: keep free NVIDIA/paid Z.AI research agents, use the
# official Claude Code CLI as the editor, and fall back to Kimi automatically.
# Authenticate `marketbrief` with a Claude subscription before enabling.
# MARKET_BRIEF_WRITER=claude
# MARKET_BRIEF_CLAUDE_MODEL=opus
# MARKET_BRIEF_CLAUDE_EFFORT=high
# CLAUDE_BIN=/home/marketbrief/.local/bin/claude

# Optional Telegram delivery. Never commit the real values.
# TELEGRAM_BOT_TOKEN=123456:replace_me
# TELEGRAM_CHAT_ID=replace_me

# Claude API/enterprise alternatives. Do NOT set ANTHROPIC_API_KEY when the
# intended billing route is the Claude.ai Pro/Max subscription.
# ANTHROPIC_API_KEY=replace_me
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1

# Optional higher-quality market data.
# TRADIER_TOKEN=replace_me
# FRED_API_KEY=replace_me
