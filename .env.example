# Copy to a location OUTSIDE this repository before filling in real values, e.g.
#   mkdir -p ~/.config/market-brief && chmod 700 ~/.config/market-brief
#   cp .env.example ~/.config/market-brief/credentials.env
#   chmod 600 ~/.config/market-brief/credentials.env
#
# Variable NAMES are not secret. Their VALUES must never be committed to Git.

# --- Portable provider chain (default backend) -------------------------------
# Kimi K3 writer (Moonshot). Required for the portable runner.
MOONSHOT_API_KEY=replace_me
# GLM-5.2 research (Z.AI global). Required for the portable runner.
ZAI_API_KEY=replace_me
# Optional free NVIDIA Build endpoint, attempted before paid Z.AI.
NVIDIA_API_KEY=replace_me

# Z.AI global default. Use the China platform endpoint only if the key
# came from there: https://open.bigmodel.cn/api/paas/v4
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4

# --- Claude backend (optional alternative) -----------------------------------
# Choose exactly one unattended route. Leave unset when using an interactive
# Claude Code subscription login, which stores its own credentials.
# ANTHROPIC_API_KEY=replace_me
# CLAUDE_CODE_USE_BEDROCK=1
# CLAUDE_CODE_USE_VERTEX=1
# CLAUDE_BIN=/path/to/claude

# --- Optional hybrid writer route ---------------------------------------------
# Keep the GLM research agents and replace only the writer with the Claude Code
# CLI on a subscription login. Kimi stays as the automatic fallback, so leave
# MOONSHOT_API_KEY configured. Do NOT set ANTHROPIC_API_KEY for this route.
# MARKET_BRIEF_WRITER=claude
# MARKET_BRIEF_CLAUDE_MODEL=opus
# MARKET_BRIEF_CLAUDE_EFFORT=high

# --- Research crawler etiquette -----------------------------------------------
# Identifiable operator contact requested by BLS/SEC fair-access policies.
# MARKET_BRIEF_CONTACT=operator@example.com

# --- Optional market data upgrades -------------------------------------------
# Tradier options chains and ORATS greeks; falls back to Yahoo when unset.
# TRADIER_TOKEN=replace_me
# TRADIER_BASE_URL=https://sandbox.tradier.com
# FRED metadata timestamps; only needed for --with-fred-meta.
# FRED_API_KEY=replace_me

# --- Optional delivery --------------------------------------------------------
# TELEGRAM_BOT_TOKEN=replace_me
# TELEGRAM_CHAT_ID=replace_me
# Gmail completion mail. Use a Google App Password, never the account password.
# GMAIL_SMTP_USER=you@gmail.com
# GMAIL_APP_PASSWORD=replace_with_16_character_app_password
# MARKET_BRIEF_EMAIL_TO=you@gmail.com

# --- Optional private mobile viewer (Cloud Run + private GCS bucket) ----------
# Unset means no upload happens at all. See deploy/cloudrun/README.md.
# GCP_PROJECT_ID=your-project-id
# MARKET_BRIEF_GCS_BUCKET=your-private-bucket
# MARKET_BRIEF_WEB_URL=https://your-private-viewer.run.app

# --- Optional path overrides (Linux service deployments) ----------------------
# MARKET_BRIEF_PROJECT=/opt/market-brief
# MARKET_BRIEF_PYTHON=/opt/market-brief/.venv/bin/python
# MARKET_BRIEF_RUNNER=/opt/market-brief/run_portable.sh
# TZ=America/Chicago
